---
import Base from "../layouts/Base.astro";
import { withBase } from "../config.mjs";
---

<Base title="Page not found" path="/404/" description="The page you’re looking for doesn’t exist.">
  <section class="section">
    <div class="container center" style="max-width:560px">
      <p class="display-xl serif">404</p>
      <h1 class="display-sm" style="margin-top:8px">This page wandered off to focus</h1>
      <p class="lede" style="margin-top:14px">
        The page you’re looking for doesn’t exist. Let’s get you back on a calmer path.
      </p>
      <div class="btn-row" style="justify-content:center;margin-top:24px">
        <a class="btn btn-primary" href={withBase("/")}>Back to home</a>
        <a class="btn btn-secondary" href={withBase("/features/")}>Features</a>
      </div>
    </div>
  </section>
</Base>
