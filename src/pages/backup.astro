---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import Shot from "../components/Shot.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";
import { storage } from "../data/app.mjs";

const gallery = [
  { file: "51_create_full_backup_dialog_light.webp", alt: "Create full backup dialog with password, confirm and hint", caption: "Set a backup password" },
  { file: "46_local_backup_screen_dark.webp", alt: "Encrypted backup screen with export, import and Drive (email masked)", caption: "Export, import, or Drive" },
  { file: "45_google_drive_connect_dialog.webp", alt: "Connect Google Drive passphrase dialog", caption: "Optional: connect Drive" },
  { file: "49_replace_data_confirm.webp", alt: "Replace local data confirmation with data counts", caption: "Restore previews first" },
];
---

<Base
  title="Encrypted Backup & Restore"
  path="/backup/"
  description="KaiZenly+ backups are encrypted and user-controlled: a local backup with a password only you know, plus optional Google Drive backup to your own hidden Drive folder."
>
  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">Backup &amp; restore</span>
        <h1 class="display-lg" style="margin-top:10px">Backups you control, encrypted by you</h1>
        <p class="lede" style="margin-top:16px">
          Because there’s no developer server, your data only leaves the device when you decide to
          back it up. Both options are encrypted and stay under your control.
        </p>
        <ul class="feature-list" style="margin-top:16px">
          <li><strong>Local backup</strong> — Data Only, or Full Backup including journal media.</li>
          <li><strong>Encrypted</strong> and locked with a password only you know.</li>
          <li><strong>Optional Google Drive backup</strong> to your own hidden Drive app folder.</li>
          <li>Restore previews the backup’s contents before replacing local data.</li>
        </ul>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta />
          <a class="btn btn-secondary" href={withBase("/privacy/")}>Privacy details</a>
        </div>
      </div>
      <div class="split-media">
        <Phone file="51_create_full_backup_dialog_light.webp" alt="Create full backup dialog" eager />
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="grid grid-2">
        <article class="card">
          <h3 style="font-family:var(--serif);font-weight:400;font-size:1.4rem">Local encrypted backup</h3>
          <p style="margin-top:10px">{storage.backupFormat}</p>
          <p class="note" style="margin-top:14px">The backup password is never stored and can’t be recovered by the app — keep it somewhere safe.</p>
        </article>
        <article class="card">
          <h3 style="font-family:var(--serif);font-weight:400;font-size:1.4rem">Optional Google Drive backup</h3>
          <p style="margin-top:10px">
            You link your own Google account and the app uploads one already-encrypted file to a
            hidden Drive app folder (appDataFolder) that only KaiZenly+ can see. Backups go to your
            Drive, never to the developer. This flow is opt-in and still in testing.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head"><h2 class="display-md">Backup &amp; restore screens</h2>
        <p class="muted" style="font-size:0.9rem">Account email is masked in these screenshots for privacy.</p>
      </div>
      <div class="grid grid-4">
        {gallery.map((s) => <Shot file={s.file} alt={s.alt} caption={s.caption} />)}
      </div>
    </div>
  </section>
</Base>
