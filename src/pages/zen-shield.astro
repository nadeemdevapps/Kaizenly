---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import Shot from "../components/Shot.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";
import { directAnswers } from "../data/app.mjs";

const gallery = [
  { file: "42_focus_setup_light_full.webp", alt: "Focus session setup with timer, start button and allowed apps", caption: "Set a timer and start" },
  { file: "20_focus_allowed_apps_picker.webp", alt: "Allowed apps picker with WhatsApp, Phone and SMS", caption: "Allow up to 8 essential apps" },
  { file: "53_focus_session_light_whatsapp.webp", alt: "Running focus session with WhatsApp allowed", caption: "A running session" },
  { file: "38_focus_protected_wall.webp", alt: "Before you leave — take a parachute to exit a session early", caption: "The parachute exit" },
  { file: "39_focus_complete_celebration.webp", alt: "Focus complete celebration with confetti", caption: "A calm completion" },
  { file: "12_insights_filled_light_scroll.webp", alt: "Scheduled focus window and bedtime mode", caption: "Schedule + bedtime mode" },
];

const zenFaqs = directAnswers.filter((f) =>
  ["What is Zen Shield focus?", "Can I use WhatsApp during Zen Shield focus?", "How is KaiZenly+ different from a simple app blocker?"].includes(f.q)
);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: zenFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to start a Zen Shield focus session in KaiZenly+",
  description:
    "Start a timed Zen Shield focus session, choose allowed essential apps, and let KaiZenly+ block distractions until the session ends.",
  step: [
    { "@type": "HowToStep", name: "Choose duration", text: "Pick the Zen Shield focus session length." },
    { "@type": "HowToStep", name: "Choose allowed apps", text: "Select up to 8 essential apps that should stay usable during focus." },
    { "@type": "HowToStep", name: "Start Zen Shield focus", text: "Start the session and stay inside the full-screen Focus Space." },
    { "@type": "HowToStep", name: "Let the Distraction Wall protect focus", text: "If a blocked app opens, KaiZenly+ shows the Distraction Wall and returns you to focus." },
  ],
};
---

<Base
  title="Zen Shield — Android App Blocker & Focus Timer | KaiZenly+"
  path="/zen-shield/"
  description="Zen Shield is KaiZenly+'s Android focus app blocker and timer. Block distracting apps, keep 8 essential apps, schedule focus sessions, and use bedtime mode."
  jsonLd={[faqSchema, howToSchema]}
>
  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">Zen Shield focus</span>
        <h1 class="display-lg" style="margin-top:10px">Android app blocking that fits real life</h1>
        <p class="lede" style="margin-top:16px">
          Zen Shield is KaiZenly+’s built-in <strong>Android app blocker and focus timer</strong>.
          Start a timed Zen Shield focus session and distracting apps are blocked, while essential
          apps like WhatsApp, phone, maps, notes, or work tools can stay available. You can also
          schedule focus windows and bedtime mode so protection starts automatically.
        </p>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta />
          <a class="btn btn-secondary" href={withBase("/compare/")}>vs simple lock apps</a>
          <a class="btn btn-ghost" href={withBase("/permissions/")}>Why it needs permissions</a>
        </div>
      </div>
      <div class="split-media">
        <Phone file="54_focus_protected_wall_light.webp" alt="Focus Protected wall with a shield, shown when the session is locked" eager />
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">How Zen Shield focus works</h2>
      </div>
      <div class="grid grid-3">
        <article class="card"><h3>Zen Shield focus timer</h3><p>Pick a duration and start a full-screen Focus Space with a live countdown and a blocked-attempt counter. Works like a screen time lock.</p></article>
        <article class="card"><h3>Allowed apps list</h3><p>Keep up to 8 essential apps — like WhatsApp, your phone dialer, maps, notes, or work tools — usable while everything else is blocked.</p></article>
        <article class="card"><h3>The Distraction Wall</h3><p>Open a blocked app and a full-screen wall returns you to Zen Shield focus, adding friction at the exact moment distraction starts.</p></article>
        <article class="card"><h3>Parachutes</h3><p>A small number of early-exit tokens make ending Zen Shield focus a deliberate decision, not a reflex.</p></article>
        <article class="card"><h3>Scheduled Zen Shield focus</h3><p>Auto-start app-blocking focus sessions at set times on the days you choose — no manual start needed.</p></article>
        <article class="card"><h3>Bedtime mode</h3><p>Automatically activate Zen Shield's app blocker during your bedtime hours to protect your sleep and digital wellbeing.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head"><h2 class="display-md">In the app</h2></div>
      <div class="grid grid-3">
        {gallery.map((s) => <Shot file={s.file} alt={s.alt} caption={s.caption} />)}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container" style="max-width:860px">
      <div class="section-head">
        <span class="eyebrow">Direct answers</span>
        <h2 class="display-md">Quick Zen Shield focus answers</h2>
      </div>
      <div class="answer-list">
        {zenFaqs.map((item) => (
          <article class="answer-card">
            <h2>{item.q}</h2>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <div class="card measure" style="margin-inline:auto">
        <h3 style="font-family:var(--serif);font-weight:400;font-size:1.4rem">Built for practical protection</h3>
        <p style="margin-top:10px">
          Zen Shield is designed to add real friction at the moments you usually lose to scrolling.
          Optional strict mode (Device Admin) can add a throttled device lock after repeated bypass
          attempts, while emergency calls stay available and essential apps can remain on your allow-list.
        </p>
      </div>
    </div>
  </section>
</Base>
