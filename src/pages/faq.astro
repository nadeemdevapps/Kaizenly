---
import Base from "../layouts/Base.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase, absUrl } from "../config.mjs";
import { faqs } from "../data/app.mjs";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Base
  title="FAQ — KaiZenly+ Habit Tracker & App Blocker"
  path="/faq/"
  description="KaiZenly+ FAQ: Is it free? How does Zen Shield work? Where is data stored? What permissions does it need? Google Drive backup and Play Store status — answered."
  jsonLd={[faqSchema]}
>
  <section class="section">
    <div class="container" style="max-width:760px">
      <span class="eyebrow">FAQ</span>
      <h1 class="display-lg" style="margin-top:10px">Questions, answered honestly</h1>
      <p class="lede" style="margin-top:16px">
        Clear answers about how KaiZenly+ works, what it stores, and where it’s headed.
      </p>

      <div style="margin-top:32px">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}<span class="plus" aria-hidden="true"></span></summary>
            <div class="faq-body">{f.a}</div>
          </details>
        ))}
      </div>

      <div class="btn-row" style="margin-top:36px">
        <DownloadCta />
        <a class="btn btn-secondary" href={withBase("/privacy/")}>Privacy model</a>
      </div>
    </div>
  </section>
</Base>
