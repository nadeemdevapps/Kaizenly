---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import Shot from "../components/Shot.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";

const gallery = [
  { file: "09_habits_with_one_habit.webp", alt: "Habits list with a single habit to start", caption: "Start with one habit" },
  { file: "08_habit_create_sheet.webp", alt: "New habit bottom sheet, Task type", caption: "Create a Task habit" },
  { file: "25_habit_create_count_dark.webp", alt: "New count habit Drink Water with a target of ten", caption: "Or a Count goal" },
  { file: "18_habit_detail_water_light.webp", alt: "Water habit detail with score, calendar and streaks", caption: "Per-habit analytics" },
  { file: "27_habit_detail_count_dark.webp", alt: "Count habit detail showing ten of ten and stats", caption: "Count progress" },
  { file: "55_home_widget_habits.webp", alt: "Home screen Today’s habits widget", caption: "Home-screen widget" },
];
---

<Base
  title="Habit Tracker — Daily Habits, Streaks & Reminders | KaiZenly+"
  path="/habits/"
  description="KaiZenly+ habit tracker for Android: Task, Count, and Scale habits with inline progress, Journal sync, custom reminders, full-screen alarms, streaks, analytics, and a widget."
>
  <section class="section">
    <div class="container split split--reverse">
      <div>
        <span class="eyebrow">Habits</span>
        <h1 class="display-lg" style="margin-top:10px">Consistency, not perfection</h1>
        <p class="lede" style="margin-top:16px">
          Habits are the heart of Kaizen — small daily steps that compound. KaiZenly+ tracks them
          calmly, with <strong>Task</strong>, <strong>Count</strong>, and <strong>Scale</strong>
          habit types, inline progress, gentle reminders, optional full-screen alarms, and
          <strong>Journal sync</strong>, so building a routine feels achievable rather than stressful.
        </p>
        <ul class="feature-list" style="margin-top:16px">
          <li>Three types: <strong>Task</strong> habits, <strong>Count</strong> goals, and <strong>Scale</strong> habits for 1-5 style daily ratings.</li>
          <li><strong>Inline logging</strong> lets Scale and Count habits update directly from the habit board.</li>
          <li><strong>Journal link</strong> connects Task and Count habits to matching Journal activities without silent auto-linking.</li>
          <li>Scale habits can be independent, or synced with Journal scales so ratings also appear in daily reflection.</li>
          <li>Independent habit progress can still appear in the daily Journal timeline as a stable <strong>Habit done</strong> snapshot.</li>
          <li>Custom reminder times, full-screen habit alarms, stop, snooze, done, missed, and quick notification actions.</li>
          <li>Streaks, best streaks, consistency %, and calendar heatmaps.</li>
          <li>Subtasks, repeat schedules, tags, and categories.</li>
        </ul>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta />
        </div>
      </div>
      <div class="split-media">
        <Phone file="43_habits_list_progress_light.webp" alt="Habits dashboard with a greeting, calendar strip and three habits with progress" eager />
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head"><h2 class="display-md">From a single tap to long-term streaks</h2></div>
      <div class="grid grid-3">
        {gallery.map((s) => <Shot file={s.file} alt={s.alt} caption={s.caption} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">Task, Count, and Scale habits</h2>
        <p class="lede">
          KaiZenly+ does not force every routine into one format. Use Task for simple completion,
          Count for measurable goals, and Scale for personal ratings like energy, sleep quality,
          stress, confidence, or focus quality. Any Scale value logged for the day counts as done.
          A Scale habit can stay independent, or sync with a Journal scale. Task and Count habits
          can also be explicitly linked with Journal activities, so your habit log becomes part of
          the same day’s reflection.
        </p>
      </div>
      <div class="grid grid-3">
        <article class="card"><h3>Task</h3><p>Best for yes/no routines such as reading, meditation, prayer, planning, or a shutdown ritual. Link it to a Journal activity when the same item should appear in reflection.</p></article>
        <article class="card"><h3>Count</h3><p>Best for numeric targets such as glasses of water, pages read, reps, or minutes practiced. Linked Count habits use an exact daily total, so repeated saves do not duplicate progress.</p></article>
        <article class="card"><h3>Scale</h3><p>Best for daily ratings. Keep it independent or sync it with Journal so the same value appears in reflection.</p></article>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">Habits and Journal can finally share the same day</h2>
        <p class="lede">
          Many trackers keep habits and journals separate. KaiZenly+ connects them deliberately:
          linked habits update Journal, Journal can update linked habits, and independent progress
          is saved into the timeline after the daily entry is saved or auto-created.
        </p>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h3>Explicit Journal link</h3>
          <p>Choose an existing Journal activity, or create one from the habit setup. Similar names can guide you, but KaiZenly+ does not silently link habits by name.</p>
        </article>
        <article class="card">
          <h3>Exact count sync</h3>
          <p>Linked Count habits save the daily total, not an extra tap. That keeps edit, save, and re-save flows duplicate-safe.</p>
        </article>
        <article class="card">
          <h3>Daily snapshots</h3>
          <p>Completed independent habits and partial Count progress can appear in the Journal timeline as <strong>Habit done</strong> chips, while missed habits stay hidden.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">Reminders when a notification is enough. Alarms when it is not.</h2>
        <p class="lede">
          Reminder and Alarm are independent for each habit. A normal reminder can show quick
          notification actions, while a full-screen alarm can ring and ask for a decision:
          done, missed, stop, or snooze for 30 minutes.
        </p>
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container center" style="max-width:600px">
      <h2 class="display-md">Start one habit today</h2>
      <p class="lede" style="margin-top:14px">That’s the whole idea — one small, calm step.</p>
      <div class="btn-row" style="justify-content:center;margin-top:22px">
        <DownloadCta size="lg" />
        <a class="btn btn-ghost" href={withBase("/insights/")}>See your progress →</a>
      </div>
    </div>
  </section>
</Base>
