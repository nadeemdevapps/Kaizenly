---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";
import { app, helpsWith, trustStrip } from "../data/app.mjs";
import { heroShots } from "../data/screenshots.mjs";
---

<Base
  path="/"
  softwareApp={true}
  description="KaiZenly+ is a free Android app — habit tracker, Zen Shield app blocker, journal, mood tracker, and routines in one. No account, no tracking, all data stays on your device."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <h1 class="display-xl">{app.name}</h1>
        <p class="display-sm serif" style="margin-top:6px;color:var(--ink-secondary)">{app.tagline}</p>
        <p class="lede">
          A calm, local-first app for <strong>habits, focus, journaling, mood, and routines</strong>.
          No developer server. No tracking. Your data stays on your device.
        </p>
        <div class="btn-row">
          <DownloadCta size="lg" />
          <a class="btn btn-secondary btn-lg" href={withBase("/features/")}>Explore features</a>
        </div>
      </div>

      <div class="hero-shots">
        {heroShots.map((s, i) => (
          <Phone file={s.file} alt={s.alt} eager={i === 0} small />
        ))}
      </div>
    </div>
  </section>

  <!-- TRUST STRIP (sliding marquee) -->
  <section class="section--tight" style="border-block:1px solid var(--hairline);padding-block:18px" aria-label="What KaiZenly+ stands for">
    <div class="marquee">
      <div class="marquee-track">
        {[...trustStrip, ...trustStrip].map((t) => (
          <span class="marquee-item">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT IT HELPS WITH -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Not just a phone blocker</span>
        <h2 class="display-md">A complete, calm self-improvement system</h2>
        <p class="lede">
          KaiZenly+ brings the parts of personal growth that usually live in five different apps
          into one quiet, private experience.
        </p>
        <div class="btn-row" style="justify-content:center;margin-top:18px">
          <a class="btn btn-ghost" href={withBase("/compare/")}>KaiZenly+ vs simple phone-lock apps →</a>
        </div>
      </div>
      <div class="grid grid-3">
        {helpsWith.map((h) => (
          <article class="card card-hover">
            <h3>{h.title}</h3>
            <p>{h.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ZEN SHIELD SPLIT -->
  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container split">
      <div>
        <span class="eyebrow">Zen Shield &amp; Focus</span>
        <h2 class="display-md" style="margin-top:10px">Protect your attention, not just block your phone</h2>
        <p class="lede" style="margin-top:14px">
          Timer-based focus sessions add real friction to distracting apps — while still letting
          essential apps like WhatsApp through. Schedule focus windows, add a bedtime mode, and
          use limited “parachute” tokens so breaking focus is always a deliberate choice.
        </p>
        <ul class="feature-list">
          <li>A focus timer (screen timer) with a full-screen Focus Space and countdown.</li>
          <li>An allowed-apps list — keep up to 8 essential apps usable during a session.</li>
          <li>A full-screen Distraction Wall when a blocked app is opened.</li>
          <li>Scheduled focus and bedtime mode that run automatically.</li>
        </ul>
        <div class="btn-row" style="margin-top:22px">
          <a class="btn btn-secondary" href={withBase("/zen-shield/")}>How Zen Shield works</a>
          <a class="btn btn-ghost" href={withBase("/compare/")}>vs simple lock apps →</a>
        </div>
        <p class="note" style="margin-top:18px">
          Designed to add friction and protect focus — not an unbreakable lock.
        </p>
      </div>
      <div class="split-media">
        <Phone file="54_focus_protected_wall_light.webp" alt="KaiZenly+ Focus Protected wall shown when a blocked app is opened" />
      </div>
    </div>
  </section>

  <!-- HABITS SPLIT -->
  <section class="section">
    <div class="container split split--reverse">
      <div>
        <span class="eyebrow">Habits</span>
        <h2 class="display-md" style="margin-top:10px">Small daily steps, tracked calmly</h2>
        <p class="lede" style="margin-top:14px">
          Build Task or Count habits with gentle reminders, streaks, and per-habit analytics.
          No guilt, no perfectionism — just consistent progress you can actually see.
        </p>
        <ul class="feature-list">
          <li>Streaks, consistency %, calendar heatmaps, and best streaks.</li>
          <li>Custom reminder times with snooze and quick notification actions.</li>
          <li>A home-screen widget to check off today’s habits in one tap.</li>
        </ul>
        <div class="btn-row" style="margin-top:22px">
          <a class="btn btn-secondary" href={withBase("/habits/")}>Explore habits</a>
        </div>
      </div>
      <div class="split-media">
        <Phone file="43_habits_list_progress_light.webp" alt="KaiZenly+ habits dashboard with progress bars and a calendar strip" />
      </div>
    </div>
  </section>

  <!-- JOURNAL + INSIGHTS SPLIT -->
  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container split">
      <div>
        <span class="eyebrow">Journal · Mood · Insights</span>
        <h2 class="display-md" style="margin-top:10px">Reflect, then understand your patterns</h2>
        <p class="lede" style="margin-top:14px">
          Write honest entries with mood check-ins, tags, and prompt templates. Then see what it
          all adds up to — mood trends, habit comparisons, and focus stats, computed entirely on
          your device.
        </p>
        <ul class="feature-list">
          <li>Mood-aware journaling with gratitude and prompt templates.</li>
          <li>Mood donut, trend lines, and a 5-week activity heatmap.</li>
          <li>Markdown and CSV export — your data stays portable.</li>
        </ul>
        <div class="btn-row" style="margin-top:22px">
          <a class="btn btn-secondary" href={withBase("/journal/")}>Journal &amp; mood</a>
          <a class="btn btn-ghost" href={withBase("/insights/")}>See insights →</a>
        </div>
      </div>
      <div class="split-media">
        <Phone file="52_insights_filled_light_clean.webp" alt="KaiZenly+ insights with mood trend and stat tiles" />
      </div>
    </div>
  </section>

  <!-- KAIZEN NAME -->
  <section class=”section”>
    <div class=”container” style=”max-width:780px;text-align:center”>
      <span class=”eyebrow”>The name</span>
      <h2 class=”display-md” style=”margin-top:10px”>Why “KaiZenly+”?</h2>
      <p class=”lede” style=”margin-top:16px”>
        The name is inspired by <strong>Kaizen</strong> — a Japanese idea meaning
        <em>”change for the better.”</em> <strong>Kai</strong> is change and progress;
        <strong>Zen</strong> is calm, focus, and balance; <strong>ly</strong> makes it a daily
        lifestyle; and <strong>+</strong> is the complete system beyond a single-feature app.
      </p>
      <p class=”secondary” style=”margin-top:14px”>
        Together: improve your life calmly, one small step at a time.<br />
        Also known as <strong>KaiZenly Plus</strong> or simply <strong>KaiZenly</strong>.
      </p>
      <div class="btn-row" style="justify-content:center;margin-top:22px">
        <a class="btn btn-ghost" href={withBase("/about/")}>Read the full story →</a>
      </div>
    </div>
  </section>

  <!-- PRIVACY BAND -->
  <section class="section--tight">
    <div class="container">
      <div class="band">
        <div class="split" style="gap:32px;align-items:center">
          <div>
            <span class="eyebrow" style="color:inherit;opacity:0.7">Privacy by default</span>
            <h2 class="display-sm" style="margin-top:8px">Your growth journey belongs to you</h2>
            <p style="margin-top:12px;max-width:52ch">
              There is no developer server and no custom backend. Your habits, moods, and journals
              live in a local encrypted database on your device. Optional Google Drive backup only
              uploads an already-encrypted file to your own account.
            </p>
          </div>
          <div class="btn-row" style="justify-content:flex-end">
            <a class="btn btn-primary" href={withBase("/privacy/")}>Read the privacy model</a>
            <a class="btn btn-secondary" href={withBase("/permissions/")}>Permissions</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS TEASER -->
  <section class="section">
    <div class="container">
      <div class="section-head center" style="margin-inline:auto">
        <span class="eyebrow">A calm, monochrome interface</span>
        <h2 class="display-md">See it in action</h2>
        <p class="lede measure" style="margin-inline:auto">
          Editorial typography, hairline cards, and a strictly monochrome palette in both dark and
          light themes.
        </p>
      </div>
      <div class="grid grid-4">
        <Phone file="01_onboarding_welcome.webp" alt="KaiZenly+ welcome screen" />
        <Phone file="15_focus_setup_light_whatsapp.webp" alt="Focus setup with WhatsApp allowed" />
        <Phone file="29_journal_filled_light.webp" alt="Journal entry with a Great mood" />
        <Phone file="44_settings_full_dark.webp" alt="Settings screen with theme and backup options" />
      </div>
      <div class="btn-row" style="justify-content:center;margin-top:34px">
        <a class="btn btn-secondary" href={withBase("/screenshots/")}>View all screenshots</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section--tight">
    <div class="container center" style="max-width:640px">
      <h2 class="display-md">Start improving, calmly</h2>
      <p class="lede" style="margin-top:14px">
        KaiZenly+ is free at launch and coming soon to Google Play — with everything kept on your
        own device.
      </p>
      <div class="btn-row" style="justify-content:center;margin-top:24px">
        <DownloadCta size="lg" />
        <a class="btn btn-ghost btn-lg" href={withBase("/faq/")}>Read the FAQ →</a>
      </div>
    </div>
  </section>
</Base>
