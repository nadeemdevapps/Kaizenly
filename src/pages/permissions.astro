---
import Base from "../layouts/Base.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";
import { permissions } from "../data/app.mjs";
---

<Base
  title="Android Permissions Explained"
  path="/permissions/"
  description="Every Android permission KaiZenly+ requests, explained line-by-line. Sensitive permissions are only asked when you enter the feature that needs them — mostly Zen Shield."
>
  <section class="section">
    <div class="container" style="max-width:820px">
      <span class="eyebrow">Permissions</span>
      <h1 class="display-lg" style="margin-top:10px">Every permission, explained</h1>
      <p class="lede" style="margin-top:16px">
        KaiZenly+ asks for sensitive permissions <strong>only</strong> when you enter a feature that
        needs them — mostly Focus / Zen Shield. Habits, journaling, mood, and insights work without
        them. Here is exactly what each one is for.
      </p>

      <div class="row-list" style="margin-top:32px">
        {permissions.map((p) => (
          <div class="row">
            <div>
              <h3>{p.name}</h3>
              <p style="margin-top:8px"><code>{p.id}</code></p>
              <p style="margin-top:6px">{p.why}</p>
            </div>
            <span class="badge badge-outline pill-need">{p.needed}</span>
          </div>
        ))}
      </div>

      <div class="card" style="margin-top:32px">
        <h3 style="font-family:var(--serif);font-weight:400;font-size:1.4rem">Prominent disclosure</h3>
        <p style="margin-top:10px">
          Before the app sends you to Android’s Accessibility or Device Admin settings, it shows a
          clear explanation of why the permission is needed and what it does. Device Admin (strict
          mode) is never enabled by default, and emergency calls always remain available.
        </p>
      </div>

      <div class="btn-row" style="margin-top:28px">
        <DownloadCta />
        <a class="btn btn-secondary" href={withBase("/privacy/")}>Read the privacy model</a>
      </div>
    </div>
  </section>
</Base>
