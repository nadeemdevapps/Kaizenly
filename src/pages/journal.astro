---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import Shot from "../components/Shot.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";

const gallery = [
  { file: "28_journal_filled_dark.webp", alt: "Journal entry with a Great mood, tags and prompts", caption: "Tags and prompts" },
  { file: "30_journal_template_gratitude.webp", alt: "Gratitude journal template with prompts", caption: "Guided templates" },
  { file: "10_journal_empty_state.webp", alt: "Empty journal with a mood picker and start with one honest line", caption: "Start with one line" },
];
---

<Base
  title="Journal & Mood Tracker | Private, On-Device"
  path="/journal/"
  description="Mood-aware journaling in KaiZenly+: unified daily records with activities, linked habits, habit snapshots, custom scales, tags, templates, photos, voice notes, and private on-device storage."
>
  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">Journal &amp; Mood</span>
        <h1 class="display-lg" style="margin-top:10px">A private space to reflect</h1>
        <p class="lede" style="margin-top:16px">
          Write an honest line or a long entry. Add a mood check-in, tags, flexible activities,
          custom emoji items, daily scales, linked habits, or a gentle prompt template. Everything
          stays on your device — journals are personal, and KaiZenly+ treats them that way.
        </p>
        <ul class="feature-list" style="margin-top:16px">
          <li>Mood check-ins scored 1–5 with labels, flexible past dates, and a 12-hour time picker.</li>
          <li>Flexible activities/categories and custom emoji items instead of only fixed lists.</li>
          <li>Custom Journal scales for energy, sleep quality, stress, confidence, focus quality, or your own rating.</li>
          <li><strong>Scale habits</strong> can sync into Journal scales, so one rating can support both habit progress and daily reflection.</li>
          <li><strong>Linked Task and Count habits</strong> can sync with Journal activities, including exact Count totals.</li>
          <li><strong>Habit done</strong> snapshots preserve completed habits and partial progress in the daily timeline.</li>
          <li>Optional photos and voice notes, stored in app-private storage.</li>
          <li>Full-text search and selective sharing, so you can export one entry, one day, or a chosen set.</li>
        </ul>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta />
          <a class="btn btn-secondary" href={withBase("/insights/")}>Turn it into insights</a>
        </div>
      </div>
      <div class="split-media">
        <Phone file="29_journal_filled_light.webp" alt="Journal entry with a Great mood and tags" eager />
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head"><h2 class="display-md">Honest, gentle, and yours</h2></div>
      <div class="grid grid-4">
        {gallery.map((s) => <Shot file={s.file} alt={s.alt} caption={s.caption} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">Flexible Journal scales and activity items</h2>
        <p class="lede">
          Journal is no longer limited to a fixed set of reflection items. You can shape it around
          your own words: custom activities, categories, emoji items, and daily scales that match how
          you actually track your day. When a habit belongs in that reflection, link it explicitly
          so the same daily action does not have to be managed twice.
        </p>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h3>Custom items</h3>
          <p>Add the activities, categories, tags, and emoji markers that make sense for your routine.</p>
        </article>
        <article class="card">
          <h3>Daily scales</h3>
          <p>Track subjective measures like energy, sleep quality, stress, confidence, or focus quality.</p>
        </article>
        <article class="card">
          <h3>Habit sync</h3>
          <p>A synced habit can add today’s activity, count, or scale value to Journal, then you can edit the entry later with full context.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head">
        <h2 class="display-md">A unified daily record</h2>
        <p class="lede">
          The Journal timeline is designed to become the daily record of what happened: mood, notes,
          activities, scales, linked habits, and independent habit progress. Manual entry stays calm,
          but the saved timeline keeps the full context.
        </p>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h3>Linked activities</h3>
          <p>Selecting a linked Journal activity can mark the matching habit done, and completing the habit can select the same activity for that date.</p>
        </article>
        <article class="card">
          <h3>Count control</h3>
          <p>Linked Count activities open a compact count sheet with plus, minus, reset, and done, then save the exact total for the day.</p>
        </article>
        <article class="card">
          <h3>Check-in entries</h3>
          <p>Auto-created sync entries use a check-in style calendar header instead of showing a neutral mood face.</p>
        </article>
      </div>
      <div class="grid grid-3" style="margin-top:24px">
        <article class="card">
          <span class="eyebrow">Screenshot slot</span>
          <h3>Synced daily timeline</h3>
          <p>Reserved for an updated screenshot showing a linked activity and the separate Habit done section in one Daily log.</p>
        </article>
        <article class="card">
          <span class="eyebrow">Screenshot slot</span>
          <h3>Linked Count control</h3>
          <p>Reserved for a screenshot showing the compact Count sheet inside Journal with plus, minus, reset, and done.</p>
        </article>
        <article class="card">
          <span class="eyebrow">Screenshot slot</span>
          <h3>Synced Scale rating</h3>
          <p>Reserved for a screenshot showing a Scale habit value reflected inside the Journal scale area.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head center" style="margin-inline:auto">
        <span class="eyebrow">Control what leaves the app</span>
        <h2 class="display-md">Share only the entries you mean to share</h2>
        <p class="lede measure" style="margin-inline:auto">
          Journal export is built for real privacy moments: select a specific entry, a whole day,
          or a hand-picked set before sharing. You stay in control of what goes into the text export.
        </p>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h3>Pick entries</h3>
          <p>Select and unselect individual journal entries before the share sheet opens.</p>
        </article>
        <article class="card">
          <h3>Share by day</h3>
          <p>Choose a full date group when you want one day's reflections without exporting everything.</p>
        </article>
        <article class="card">
          <h3>Backdate moods</h3>
          <p>Add mood entries for earlier days, with a readable 12-hour time picker for the exact moment.</p>
        </article>
      </div>
    </div>
  </section>
</Base>
