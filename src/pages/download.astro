---
import Base from "../layouts/Base.astro";
import Phone from "../components/Phone.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { withBase } from "../config.mjs";
import { app } from "../data/app.mjs";
---

<Base
  title="Download KaiZenly+ — Free Android Habit Tracker & App Blocker"
  path="/download/"
  softwareApp={true}
  description="Download KaiZenly+ for Android — free habit tracker, Zen Shield app blocker, journal and mood tracker in one app. Version 1.0.0, coming to Google Play. Requires Android 8.0+."
>
  <section class="section">
    <div class="container split">
      <div>
        <h1 class="display-lg">Coming soon to Google Play</h1>
        <p class="lede" style="margin-top:16px">
          KaiZenly+ is on its way to the Play Store. It will be free at launch, with every feature
          included — and once it is listed you will be able to install it in one tap, straight from
          Google Play. No direct downloads, no side-loading.
        </p>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta size="lg" />
          <a class="btn btn-secondary btn-lg" href={withBase("/features/")}>Explore features</a>
        </div>
        <p class="hero-note">
          Version {app.version} · {app.platform} · {app.minAndroid} or newer. There is no Play Store
          badge, rating, or review yet because there is no public listing — those will appear only
          when they are real.
        </p>

        <div class="card" style="margin-top:28px">
          <h3 style="font-family:var(--sans);font-weight:600">What to expect</h3>
          <ul class="feature-list" style="margin-top:10px">
            <li>Install directly from Google Play when the listing goes live.</li>
            <li>Free at launch, with every feature included.</li>
            <li>No account and no internet connection required for normal use.</li>
          </ul>
        </div>
      </div>
      <div class="split-media">
        <Phone file="01_onboarding_welcome.webp" alt="KaiZenly+ welcome screen" eager />
      </div>
    </div>
  </section>

  <section class="section--tight">
    <div class="container center" style="max-width:600px">
      <h2 class="display-md">Questions first?</h2>
      <p class="lede" style="margin-top:12px">See how it handles your data before it launches.</p>
      <div class="btn-row" style="justify-content:center;margin-top:20px">
        <a class="btn btn-secondary" href={withBase("/privacy/")}>Privacy</a>
        <a class="btn btn-secondary" href={withBase("/permissions/")}>Permissions</a>
        <a class="btn btn-ghost" href={withBase("/faq/")}>FAQ →</a>
      </div>
    </div>
  </section>
</Base>
