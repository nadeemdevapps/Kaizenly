---
import Base from "../layouts/Base.astro";
import DownloadCta from "../components/DownloadCta.astro";
import { app } from "../data/app.mjs";
import { withBase } from "../config.mjs";

const releaseDate = "July 1, 2026";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is new in KaiZenly+ 1.4.3?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "KaiZenly+ 1.4.3 adds unified Journal and Habit sync, explicit Journal links for Task and Count habits, linked Count controls in Journal, synced Scale habits, independent habit snapshots in the timeline, editable Journal entries, auto-created check-in entries, full-screen habit alarms, and smoother habit setup UX.",
      },
    },
    {
      "@type": "Question",
      name: "How does unified Journal and Habit sync work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Users can explicitly link a habit to a Journal activity. Completing a linked habit can update that day's Journal entry, and selecting the linked Journal activity can update the habit. Count habits save an exact daily total, Scale habits sync with Journal scales, and independent habit progress can appear in the Journal timeline as snapshots.",
      },
    },
    {
      "@type": "Question",
      name: "What are Scale habits?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Scale habits are daily rating habits for things like energy, sleep quality, stress, confidence, or focus quality. They can be independent or synced with a Journal scale. Any logged scale value counts as done for the day.",
      },
    },
    {
      "@type": "Question",
      name: "What changed in Journal?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Journal now supports flexible activities and categories, custom emoji items, custom scales, linked Task and Count habits, linked Count controls, habit snapshots, edit/delete menus, and auto-created check-in entries that do not show a neutral mood face.",
      },
    },
    {
      "@type": "Question",
      name: "How are full-screen habit alarms different from reminders?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Normal reminders use notifications. Full-screen habit alarms can ring on screen and let the user mark a habit done, mark it missed, or snooze it for 30 minutes. Reminder and Alarm are independent for each habit.",
      },
    },
  ],
};
---

<Base
  title="What’s New in KaiZenly+ 1.4.3 — Unified Journal & Habit Sync"
  path="/whats-new/"
  softwareApp={true}
  jsonLd={[faqSchema]}
  description="KaiZenly+ 1.4.3 adds unified Journal and Habit sync, linked Count controls, habit snapshots, editable Journal entries, synced Scale habits, full-screen alarms, and smoother habit setup UX."
>
  <section class="section">
    <div class="container" style="max-width:820px">
      <span class="eyebrow">What’s new</span>
      <h1 class="display-lg" style="margin-top:10px">KaiZenly+ {app.version}: Unified Journal and Habit sync</h1>
      <p class="lede" style="margin-top:16px">
        Released {releaseDate}, KaiZenly+ {app.version} expands the habit and Journal system with
        <strong>unified daily records</strong>, linked Task and Count habits, synced Scale habits,
        editable Journal entries, independent habit snapshots, and full-screen habit alarms, while
        keeping the same local-first privacy model.
      </p>
      <p class="lede" style="margin-top:14px">
        This is the release that makes KaiZenly+ feel like one connected self-improvement system:
        habits are no longer trapped in one tab while Journal lives somewhere else. The same day can
        now carry actions, mood, ratings, counts, and reflection together.
      </p>
      <div class="btn-row" style="margin-top:24px">
        <DownloadCta />
        <a class="btn btn-secondary" href={withBase("/blog/unified-daily-records/")}>Read the guide</a>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="grid grid-3">
        <article class="card">
          <h2 class="display-sm">Unified daily record</h2>
          <p>
            Journal can now preserve mood, activities, scales, linked habits, and independent habit
            progress in one daily timeline, instead of forcing users to manage habit and Journal data separately.
          </p>
        </article>
        <article class="card">
          <h2 class="display-sm">Linked habits</h2>
          <p>
            Task and Count habits can be explicitly linked with Journal activities. Completing a
            linked habit can update Journal, and selecting the activity can update the habit.
          </p>
        </article>
        <article class="card">
          <h2 class="display-sm">Scale habits</h2>
          <p>
            Scale sliders are blank by default, monochrome, smooth, and can log directly from the
            habit board. Synced Scale values also appear in daily Journal reflection.
          </p>
        </article>
        <article class="card">
          <h2 class="display-sm">Journal editing</h2>
          <p>
            Entries can now be edited from a three-dot menu. Users can re-choose mood, activities,
            scales, linked counts, notes, photos, and voice context.
          </p>
        </article>
        <article class="card">
          <h2 class="display-sm">Full-screen alarms</h2>
          <p>
            Habit Alarm is now separate from Reminder. Use a normal notification, a ringing
            full-screen alarm, both, or neither. Alarms support done, missed, and 30-minute snooze.
          </p>
        </article>
        <article class="card">
          <h2 class="display-sm">Timeline snapshots</h2>
          <p>
            Auto-created entries show a check-in header instead of a neutral mood face. The timeline
            can show a separate <strong>Habit done</strong> row for completed and partial habit progress.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:860px">
      <div class="section-head">
        <h2 class="display-md">Detailed update summary</h2>
        <p class="lede">
          This release is designed for users who want a calmer routine system, not just a checklist.
        </p>
      </div>
      <div class="grid grid-2">
        <article class="card">
          <h3>Habits</h3>
          <ul class="feature-list">
            <li>Task habits for simple yes/no routines.</li>
            <li>Count habits for measurable daily targets.</li>
            <li>Scale habits for subjective daily ratings.</li>
            <li>Scale habits can now be logged inline from the habit board.</li>
            <li>Count habits show cleaner inline progress with the selected number or count label.</li>
            <li>Task and Count habits can be explicitly linked with Journal activities.</li>
            <li>Scale habits can be independent or synced with Journal scales.</li>
            <li>Synced habit logs can create or update that day’s Journal entry.</li>
            <li>Custom scale creation inside habit setup.</li>
          </ul>
        </article>
        <article class="card">
          <h3>Journal</h3>
          <ul class="feature-list">
            <li>Flexible activities and categories instead of only fixed reflection items.</li>
            <li>Custom emoji items for personal journaling language.</li>
            <li>Custom daily scales for energy, stress, sleep quality, focus quality, or similar measures.</li>
            <li>Linked Count activities open a compact count control and save the exact daily total.</li>
            <li>Synced values can be edited later with mood, notes, tags, photos, and voice.</li>
            <li>Edit removal can unset matching linked habit or scale values after confirmation.</li>
            <li>Auto-created sync entries use a check-in style header instead of a neutral mood face.</li>
          </ul>
        </article>
        <article class="card">
          <h3>Unified timeline</h3>
          <ul class="feature-list">
            <li>Manual Journal activities remain in their normal chip area.</li>
            <li>A separate <strong>Habit done</strong> section can show completed habit snapshots.</li>
            <li>Partial Count habits can appear as labels such as Water 4/8.</li>
            <li>Missed or zero-progress habits stay hidden from the timeline.</li>
            <li>Independent habit data is imported on save or auto-log without cluttering the composer.</li>
          </ul>
        </article>
        <article class="card">
          <h3>Reminders and alarms</h3>
          <ul class="feature-list">
            <li>Normal reminders stay available for lightweight nudges.</li>
            <li>Full-screen alarms are available for habits that need stronger attention.</li>
            <li>Reminder and Alarm can be configured independently.</li>
            <li>Alarm actions support done, missed, and 30-minute snooze.</li>
          </ul>
        </article>
        <article class="card">
          <h3>Daily record</h3>
          <ul class="feature-list">
            <li>Habit records now support explicit Journal activity links.</li>
            <li>Journal entries preserve stable activity selections and habit progress context.</li>
            <li>Daily snapshots keep timeline history stable even when habits change later.</li>
            <li>No developer server, no mandatory account, no analytics, and no ads.</li>
          </ul>
        </article>
        <article class="card">
          <h3>Zen Shield</h3>
          <ul class="feature-list">
            <li>Approved essentials include Phone, Messaging/SMS, WhatsApp, Gmail, Outlook, Google Keep, AI/productivity tools, and major banking/payment apps where installed.</li>
            <li>Broad social and streaming apps are not treated as essentials.</li>
            <li>Missing banking or productivity apps can be requested from inside the app.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</Base>
