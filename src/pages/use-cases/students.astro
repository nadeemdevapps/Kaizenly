---
import Base from "../../layouts/Base.astro";
import Phone from "../../components/Phone.astro";
import DownloadCta from "../../components/DownloadCta.astro";
import { withBase } from "../../config.mjs";
---

<Base
  title="KaiZenly+ for Students — Study Focus & Habit Tracker"
  path="/use-cases/students/"
  description="How students use KaiZenly+: protect study time with Zen Shield, keep WhatsApp available, build study habits, journal, and track progress — free and private, no account needed."
>
  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">For students</span>
        <h1 class="display-lg" style="margin-top:10px">Study time, protected</h1>
        <p class="lede" style="margin-top:16px">
          KaiZenly+ was built by a student, for the very real problem of losing study hours to the
          phone. It helps you carve out focused time, keep the essentials available, and build study
          habits that actually stick — for free, with nothing leaving your device.
        </p>
        <div class="btn-row" style="margin-top:24px">
          <DownloadCta />
        </div>
      </div>
      <div class="split-media">
        <Phone file="53_focus_session_light_whatsapp.webp" alt="Running focus session with WhatsApp allowed" eager />
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--surface);border-block:1px solid var(--hairline)">
    <div class="container">
      <div class="section-head"><h2 class="display-md">A student’s day with KaiZenly+</h2></div>
      <div class="grid grid-3">
        <article class="card"><h3>Block during lectures</h3><p>Start a focus session so social apps are blocked, while WhatsApp and your dialer stay reachable.</p></article>
        <article class="card"><h3>Build study habits</h3><p>Track “Read 20 minutes”, “Revise notes”, or “Sleep by 11” with gentle reminders and streaks.</p></article>
        <article class="card"><h3>Schedule focus + bedtime</h3><p>Auto-start a morning study window and a bedtime mode so good routines run themselves.</p></article>
        <article class="card"><h3>Reflect briefly</h3><p>One honest journal line a day plus a mood check-in builds self-awareness over a term.</p></article>
        <article class="card"><h3>See progress</h3><p>On-device insights show focus minutes and habit consistency — motivation without comparison.</p></article>
        <article class="card"><h3>Free &amp; private</h3><p>No subscription, no login, no data leaving your phone. Ideal on a student budget.</p></article>
      </div>
      <div class="btn-row" style="margin-top:32px">
        <a class="btn btn-secondary" href={withBase("/zen-shield/")}>How focus works</a>
        <a class="btn btn-ghost" href={withBase("/use-cases/professionals/")}>For professionals →</a>
      </div>
    </div>
  </section>
</Base>
