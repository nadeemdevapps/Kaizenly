---
import { SITE, withBase } from "../config.mjs";
import { app } from "../data/app.mjs";

const cols = [
  {
    title: "Product",
    links: [
      { path: "/features/", label: "Features" },
      { path: "/zen-shield/", label: "Zen Shield & Focus" },
      { path: "/compare/", label: "vs simple lock apps" },
      { path: "/design/", label: "Design philosophy" },
      { path: "/habits/", label: "Habits" },
      { path: "/journal/", label: "Journal & Mood" },
      { path: "/insights/", label: "Insights" },
      { path: "/backup/", label: "Backup" },
    ],
  },
  {
    title: "Trust",
    links: [
      { path: "/privacy/", label: "Privacy" },
      { path: "/permissions/", label: "Permissions" },
      { path: "/why-kaizenly/", label: "Why KaiZenly+" },
      { path: "/about/", label: "About the founder" },
      { path: "/about/#contact", label: "Contact" },
    ],
  },
  {
    title: "More",
    links: [
      { path: "/screenshots/", label: "Screenshots" },
      { path: "/use-cases/students/", label: "For students" },
      { path: "/use-cases/professionals/", label: "For professionals" },
      { path: "/faq/", label: "FAQ" },
      { path: "/download/", label: "Download" },
    ],
  },
  {
    title: "Legal",
    links: [
      { path: "/privacy-policy/", label: "Privacy Policy" },
      { path: "/terms/", label: "Terms & Conditions" },
      { path: "/data-safety/", label: "Data Safety" },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a class="brand" href={withBase("/")} style="margin-bottom:14px">
          <img src={withBase("/favicon.svg")} alt="" width="28" height="28" />
          <span>{SITE.name}</span>
        </a>
        <p class="secondary" style="font-size:0.92rem;max-width:34ch">{app.tagline}</p>
        <p class="muted" style="font-size:0.82rem;margin-top:14px">
          Privacy-first Android app for habits, focus, journaling, mood, and routines.
          Local-first. No tracking.
        </p>
      </div>

      {cols.map((col) => (
        <div class="footer-col">
          <h4>{col.title}</h4>
          {col.links.map((l) => (
            <a href={withBase(l.path)}>{l.label}</a>
          ))}
        </div>
      ))}
    </div>

    <div class="footer-bottom">
      <span>© {year} {SITE.name}. All rights reserved.</span>
      <span class="tag-row" style="gap:16px">
        <a href={withBase("/privacy-policy/")} class="muted">Privacy Policy</a>
        <a href={withBase("/terms/")} class="muted">Terms</a>
        <a href={withBase("/data-safety/")} class="muted">Data Safety</a>
        <a href={withBase("/llms.txt")} class="muted">llms.txt</a>
      </span>
    </div>
  </div>
</footer>
