---
import { SITE, withBase } from "../config.mjs";

const navItems = [
  { path: "/features/", label: "Features" },
  { path: "/zen-shield/", label: "Zen Shield" },
  { path: "/compare/", label: "Compare" },
  { path: "/privacy/", label: "Privacy" },
  { path: "/screenshots/", label: "Screenshots" },
  { path: "/about/", label: "About" },
];

const here = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (p) => {
  const target = withBase(p).replace(/\/+$/, "") || "/";
  return here === target;
};
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href={withBase("/")} aria-label={`${SITE.name} home`}>
      <img src={withBase("/favicon.svg")} alt="" width="28" height="28" />
      <span>{SITE.name}</span>
    </a>

    <nav class="nav-links" data-nav-links aria-label="Primary">
      {navItems.map((item) => (
        <a href={withBase(item.path)} aria-current={isActive(item.path) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
      <a class="btn btn-primary nav-cta" href={withBase("/download/")}>Download</a>
    </nav>

    <button class="theme-toggle" data-theme-toggle type="button" aria-label="Toggle light and dark theme" title="Toggle theme">
      <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4.2" />
        <path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19" />
      </svg>
      <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </button>

    <button class="nav-toggle" data-nav-toggle type="button" aria-label="Open menu" aria-expanded="false">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </div>
</header>
