---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE, absUrl, withBase } from "../config.mjs";
import { app } from "../data/app.mjs";

const {
  title,
  description = SITE.shortDescription,
  path = "/",
  ogImage = "/og-image.png",
  softwareApp = false,
  jsonLd = [],
} = Astro.props;

const pageTitle = title
  ? title.includes(SITE.name) ? title : `${title} — ${SITE.name}`
  : `${SITE.name} — ${app.tagline}`;
const canonical = absUrl(path);
const ogImageUrl = absUrl(ogImage);

// Organization schema — helps Google learn the brand name for search result labels
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": absUrl("/#organization"),
  name: "KaiZenly+",
  alternateName: ["KaiZenly Plus", "KaiZenly", "Kaizenly", "Kaizenly Plus", "kaizenly+"],
  url: absUrl("/"),
  logo: {
    "@type": "ImageObject",
    url: absUrl("/icon-512.png"),
    width: 512,
    height: 512,
  },
  sameAs: [
    "https://github.com/nadeemdevapps",
    absUrl("/"),
  ],
  contactPoint: {
    "@type": "ContactPoint",
    email: "kaizenlyplus@gmail.com",
    contactType: "customer support",
  },
  founder: {
    "@type": "Person",
    name: "Nadeem Mazhar",
    email: "kaizenlyplus@gmail.com",
    address: { "@type": "PostalAddress", addressCountry: "PK" },
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": absUrl("/#website"),
  name: SITE.name,
  alternateName: ["KaiZenly Plus", "KaiZenly", "Kaizenly", "Kaizenly Plus", "kaizenly+"],
  url: absUrl("/"),
  description: SITE.shortDescription,
  inLanguage: "en",
  publisher: { "@id": absUrl("/#organization") },
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: absUrl("/?q={search_term_string}") },
    "query-input": "required name=search_term_string",
  },
};

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: app.name,
  alternateName: ["KaiZenly Plus", "KaiZenly", "Kaizenly", "Kaizenly Plus", "kaizenly+"],
  operatingSystem: "Android 8.0+",
  applicationCategory: "ProductivityApplication",
  applicationSubCategory: "Habit Tracker, Focus App, Journal, Mood Tracker",
  softwareVersion: app.version,
  description:
    "KaiZenly+ is a privacy-first Android app for habit tracking, focus sessions (Zen Shield), journaling, mood tracking, routines, and on-device insights. Local-first, no account, no tracking.",
  url: absUrl("/"),
  downloadUrl: absUrl("/download/"),
  installUrl: absUrl("/download/"),
  privacyPolicy: absUrl("/privacy-policy/"),
  isAccessibleForFree: true,
  keywords:
    "habit tracker, focus app, Android productivity, app blocker, app blocker for Android, Blockit alternative, Zen Shield, Zen Shield app blocker, journaling app, mood tracker, screen time, screen time control, focus timer, privacy-first, local-first, no tracking, daily routine, self-improvement, KaiZenly",
  featureList:
    "Habit tracking with streaks and reminders, Zen Shield focus sessions with app blocking, Allowed-apps list for essential apps during focus, Scheduled focus windows and bedtime mode, Journal with mood check-ins and prompt templates, On-device insights with mood trends and habit stats, Local encrypted backup and optional Google Drive backup, Home-screen habit widget, No developer server, No mandatory login, No tracking or ads",
  screenshot: [
    absUrl("/screenshots/43_habits_list_progress_light.webp"),
    absUrl("/screenshots/53_focus_session_light_whatsapp.webp"),
    absUrl("/screenshots/52_insights_filled_light_clean.webp"),
    absUrl("/screenshots/29_journal_filled_light.webp"),
  ],
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Person",
    name: "Nadeem Mazhar",
    nationality: "Pakistani",
    email: "kaizenlyplus@gmail.com",
    address: { "@type": "PostalAddress", addressCountry: "PK" },
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: "kaizenlyplus@gmail.com",
    contactType: "customer support",
  },
};

const schemas = [organizationSchema, websiteSchema, ...(softwareApp ? [softwareSchema] : []), ...jsonLd];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="ejHezyBhrzbieh6OZO6HErap8Nu1Zi-b3Ov3p8z2Hko" />
    <meta name="keywords" content="KaiZenly+, KaiZenly Plus, KaiZenly, Kaizenly, kaizenly+, app blocker, habit tracker, focus app, Android productivity, Zen Shield, Blockit alternative, journal app, mood tracker, screen time" />

    <!-- Theme: set before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("kz-theme");
          if (t === "light" || t === "dark") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>
    <meta name="theme-color" content="#0f0f0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f2f2f2" media="(prefers-color-scheme: light)" />

    <!-- Icons — all formats so Google, browsers, and PWAs all pick up the right one -->
    <link rel="shortcut icon" href={withBase("/favicon.ico")} />
    <link rel="icon" type="image/x-icon" href={withBase("/favicon.ico")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/icon-32.png")} />
    <link rel="icon" type="image/png" sizes="48x48" href={withBase("/icon-48.png")} />
    <link rel="icon" type="image/png" sizes="192x192" href={withBase("/icon-192.png")} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase("/icon-180.png")} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />

    <!-- Fonts: serif display (EB Garamond) + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${SITE.name} — ${app.tagline}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Minimal interactivity: theme toggle + mobile nav. Content is fully static. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        function current() {
          return root.getAttribute("data-theme") === "light" ? "light" : "dark";
        }
        var toggle = document.querySelector("[data-theme-toggle]");
        if (toggle) {
          toggle.addEventListener("click", function () {
            var next = current() === "light" ? "dark" : "light";
            root.setAttribute("data-theme", next);
            try { localStorage.setItem("kz-theme", next); } catch (e) {}
          });
        }
        var navToggle = document.querySelector("[data-nav-toggle]");
        var navLinks = document.querySelector("[data-nav-links]");
        if (navToggle && navLinks) {
          navToggle.addEventListener("click", function () {
            var open = navLinks.classList.toggle("open");
            navToggle.setAttribute("aria-expanded", open ? "true" : "false");
          });
          navLinks.addEventListener("click", function (e) {
            if (e.target.tagName === "A") navLinks.classList.remove("open");
          });
        }
      })();
    </script>
  </body>
</html>
